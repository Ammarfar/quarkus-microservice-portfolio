      <bpmn2:incoming>SF_Main_5</bpmn2:incoming>
      <bpmn2:outgoing>SF_Main_5B</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="Task_ReleaseInventory_eventInputX" drools:dtype="com.ammar.checkout.service.model.CheckoutRequestedEvent" itemSubjectRef="_Task_ReleaseInventory_eventInputXItem" name="event"/>
        <bpmn2:inputSet>
