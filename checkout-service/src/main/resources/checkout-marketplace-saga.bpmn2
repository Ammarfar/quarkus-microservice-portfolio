  </bpmn2:collaboration>
  <bpmn2:process id="checkoutMarketplaceSaga" drools:packageName="com.ammar.checkout" drools:version="1.0" drools:adHoc="false" name="Checkout Marketplace Saga" isExecutable="true" processType="Private">
    <bpmn2:property id="event" itemSubjectRef="_eventItem" name="event"/>
    <bpmn2:property id="shouldProcess" itemSubjectRef="_shouldProcessItem" name="shouldProcess"/>
    <bpmn2:property id="inventoryReserved" itemSubjectRef="_inventoryReservedItem" name="inventoryReserved"/>
    <bpmn2:property id="processSuccess" itemSubjectRef="_processSuccessItem" name="processSuccess"/>
    <bpmn2:sequenceFlow id="SF_Main_1" sourceRef="Start_CheckoutRequested" targetRef="Task_ValidateRequest"/>
    <bpmn2:sequenceFlow id="SF_Main_2" sourceRef="Task_ValidateRequest" targetRef="Gateway_ShouldProcess"/>
    <bpmn2:sequenceFlow id="SF_Main_5" sourceRef="Throw_CompensateInventory" targetRef="Task_ReleaseInventory"/>
    <bpmn2:sequenceFlow id="SF_Main_5B" sourceRef="Task_ReleaseInventory" targetRef="Task_PublishCheckoutFailed_Compensated"/>
    <bpmn2:sequenceFlow id="SF_Main_2B" sourceRef="Gateway_ShouldProcess" targetRef="Gateway_Finish">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java"><![CDATA[shouldProcess == false]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SF_Main_6" sourceRef="Task_PublishCheckoutFailed_Compensated" targetRef="Gateway_Finish"/>
    <bpmn2:sequenceFlow id="SF_Main_7" sourceRef="Gateway_Finish" targetRef="End_CheckoutDone"/>
    <bpmn2:sequenceFlow id="SF_Main_3" sourceRef="SubProcess_CheckoutSagaScope" targetRef="Gateway_Finish"/>
    <bpmn2:sequenceFlow id="SF_Main_2A" sourceRef="Gateway_ShouldProcess" targetRef="SubProcess_CheckoutSagaScope">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java"><![CDATA[shouldProcess == true]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SF_Main_4_Trigger" sourceRef="Boundary_ProcessFailed" targetRef="Throw_CompensateInventory"/>
    <bpmn2:startEvent id="Start_CheckoutRequested" name="Checkout Requested">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Checkout Requested]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:outgoing>SF_Main_1</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:serviceTask id="Task_ValidateRequest" drools:serviceimplementation="Java" drools:serviceinterface="com.ammar.checkout.workflow.CheckoutSagaWorkflowService" drools:serviceoperation="validateRequestAndIdempotency" name="Validate Request + Idempotency Check" implementation="Java" operationRef="Task_ValidateRequest_ServiceOperation">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Validate Request + Idempotency Check]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SF_Main_1</bpmn2:incoming>
      <bpmn2:outgoing>SF_Main_2</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="Task_ValidateRequest_eventInputX" drools:dtype="com.ammar.checkout.service.model.CheckoutRequestedEvent" itemSubjectRef="_Task_ValidateRequest_eventInputXItem" name="event"/>
        <bpmn2:dataOutput id="Task_ValidateRequest_resultOutputX" drools:dtype="Boolean" itemSubjectRef="_Task_ValidateRequest_resultOutputXItem" name="result"/>
        <bpmn2:inputSet>
