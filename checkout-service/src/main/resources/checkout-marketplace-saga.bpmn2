    </bpmn2:serviceTask>
    <bpmn2:serviceTask id="Task_PublishCheckoutFailed_Compensated" drools:serviceimplementation="Java" drools:serviceinterface="com.ammar.checkout.workflow.CheckoutSagaWorkflowService" drools:serviceoperation="publishCheckoutFailedCompensated" name="Publish checkout.failed (compensated)" implementation="Java" operationRef="Task_PublishCheckoutFailed_Compensated_ServiceOperation">
