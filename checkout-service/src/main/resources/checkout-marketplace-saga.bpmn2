        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>Task_ValidateRequest_resultOutputX</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>event</bpmn2:sourceRef>
        <bpmn2:targetRef>Task_ValidateRequest_eventInputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>Task_ValidateRequest_resultOutputX</bpmn2:sourceRef>
        <bpmn2:targetRef>shouldProcess</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:serviceTask>
    <bpmn2:exclusiveGateway id="Gateway_ShouldProcess" name="Valid And Not Duplicated?" gatewayDirection="Diverging">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Valid And Not Duplicated?]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SF_Main_2</bpmn2:incoming>
      <bpmn2:outgoing>SF_Main_2A</bpmn2:outgoing>
      <bpmn2:outgoing>SF_Main_2B</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:intermediateThrowEvent id="Throw_CompensateInventory" name="Trigger Compensation">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Trigger Compensation]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SF_Main_4_Trigger</bpmn2:incoming>
      <bpmn2:outgoing>SF_Main_5</bpmn2:outgoing>
      <bpmn2:compensateEventDefinition/>
    </bpmn2:intermediateThrowEvent>
    <bpmn2:serviceTask id="Task_ReleaseInventory" drools:serviceimplementation="Java" drools:serviceinterface="com.ammar.checkout.workflow.CheckoutSagaWorkflowService" drools:serviceoperation="releaseInventory" name="Release Inventory (Compensation)" implementation="Java" operationRef="Task_ReleaseInventory_ServiceOperation">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Release Inventory (Compensation)]]></drools:metaValue>
