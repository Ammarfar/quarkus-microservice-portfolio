        <bpmn2:targetRef>Task_PublishCheckoutFailed_Compensated_eventInputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
    </bpmn2:serviceTask>
    <bpmn2:exclusiveGateway id="Gateway_Finish" name="Finish" gatewayDirection="Converging">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Finish]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SF_Main_3</bpmn2:incoming>
      <bpmn2:incoming>SF_Main_2B</bpmn2:incoming>
      <bpmn2:incoming>SF_Main_6</bpmn2:incoming>
      <bpmn2:outgoing>SF_Main_7</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:endEvent id="End_CheckoutDone" name="Checkout Finished">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Checkout Finished]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SF_Main_7</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:subProcess id="SubProcess_CheckoutSagaScope" name="Checkout Saga Scope">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Checkout Saga Scope]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SF_Main_2A</bpmn2:incoming>
      <bpmn2:outgoing>SF_Main_3</bpmn2:outgoing>
      <bpmn2:sequenceFlow id="SF_Sub_1" sourceRef="SubStart" targetRef="Task_ReserveInventory"/>
      <bpmn2:sequenceFlow id="SF_Sub_2" sourceRef="Task_ReserveInventory" targetRef="Gateway_InventoryReserved"/>
      <bpmn2:sequenceFlow id="SF_Sub_4" sourceRef="Gateway_InventoryReserved" targetRef="Task_PublishCheckoutFailed_NoReserve">
        <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java"><![CDATA[inventoryReserved == false]]></bpmn2:conditionExpression>
      </bpmn2:sequenceFlow>
      <bpmn2:sequenceFlow id="SF_Sub_3" sourceRef="Gateway_InventoryReserved" targetRef="Task_ProcessCheckout">
        <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java"><![CDATA[inventoryReserved == true]]></bpmn2:conditionExpression>
      </bpmn2:sequenceFlow>
      <bpmn2:sequenceFlow id="SF_Sub_6" sourceRef="Task_ProcessCheckout" targetRef="Gateway_ProcessSuccess"/>
      <bpmn2:sequenceFlow id="SF_Sub_7" sourceRef="Gateway_ProcessSuccess" targetRef="Task_PublishCheckoutCompleted">
        <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java"><![CDATA[processSuccess == true]]></bpmn2:conditionExpression>
      </bpmn2:sequenceFlow>
      <bpmn2:sequenceFlow id="SF_Sub_9" sourceRef="Gateway_ProcessSuccess" targetRef="End_ErrorProcessFailed">
        <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java"><![CDATA[processSuccess == false]]></bpmn2:conditionExpression>
      </bpmn2:sequenceFlow>
      <bpmn2:sequenceFlow id="SF_Sub_8" sourceRef="Task_PublishCheckoutCompleted" targetRef="SubEnd_Success"/>
      <bpmn2:sequenceFlow id="SF_Sub_5" sourceRef="Task_PublishCheckoutFailed_NoReserve" targetRef="SubEnd_FailedNoReserve"/>
      <bpmn2:startEvent id="SubStart">
        <bpmn2:outgoing>SF_Sub_1</bpmn2:outgoing>
      </bpmn2:startEvent>
      <bpmn2:serviceTask id="Task_ReserveInventory" drools:serviceimplementation="Java" drools:serviceinterface="com.ammar.checkout.workflow.CheckoutSagaWorkflowService" drools:serviceoperation="reserveInventory" name="Reserve Inventory" implementation="Java" operationRef="Task_ReserveInventory_ServiceOperation">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Reserve Inventory]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>SF_Sub_1</bpmn2:incoming>
        <bpmn2:outgoing>SF_Sub_2</bpmn2:outgoing>
        <bpmn2:ioSpecification>
          <bpmn2:dataInput id="Task_ReserveInventory_eventInputX" drools:dtype="com.ammar.checkout.service.model.CheckoutRequestedEvent" itemSubjectRef="_Task_ReserveInventory_eventInputXItem" name="event"/>
          <bpmn2:dataOutput id="Task_ReserveInventory_resultOutputX" drools:dtype="Boolean" itemSubjectRef="_Task_ReserveInventory_resultOutputXItem" name="result"/>
          <bpmn2:inputSet>
            <bpmn2:dataInputRefs>Task_ReserveInventory_eventInputX</bpmn2:dataInputRefs>
          </bpmn2:inputSet>
          <bpmn2:outputSet>
            <bpmn2:dataOutputRefs>Task_ReserveInventory_resultOutputX</bpmn2:dataOutputRefs>
          </bpmn2:outputSet>
        </bpmn2:ioSpecification>
        <bpmn2:dataInputAssociation>
          <bpmn2:sourceRef>event</bpmn2:sourceRef>
          <bpmn2:targetRef>Task_ReserveInventory_eventInputX</bpmn2:targetRef>
        </bpmn2:dataInputAssociation>
        <bpmn2:dataOutputAssociation>
          <bpmn2:sourceRef>Task_ReserveInventory_resultOutputX</bpmn2:sourceRef>
          <bpmn2:targetRef>inventoryReserved</bpmn2:targetRef>
        </bpmn2:dataOutputAssociation>
      </bpmn2:serviceTask>
      <bpmn2:exclusiveGateway id="Gateway_InventoryReserved" name="Inventory Reserved?" gatewayDirection="Diverging">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Inventory Reserved?]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>SF_Sub_2</bpmn2:incoming>
        <bpmn2:outgoing>SF_Sub_3</bpmn2:outgoing>
